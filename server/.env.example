# --- Server ---------------------------------------------------------
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# --- Database -------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/faaexaminations
# Or individual fields:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=faaexaminations

# --- Auth ----------------------------------------------------------
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- Stripe (optional) ---------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
